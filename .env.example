# ── VitalWatch 2.0 Environment Variables ──────────────────────────────────────

# OpenAI API key (required for RAG chatbot)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Database connection string
# Option A — Supabase (recommended):
#   Go to supabase.com → your project → Settings → Database → URI
# DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# Option B — Local PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/vitalwatch

# Option C — SQLite (zero setup, for local testing only):
# DATABASE_URL=sqlite:///./vitalwatch.db
# (leave DATABASE_URL blank to use SQLite automatically)
